{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lapjan1.github.io/maori-sre/schemas/visit-course.schema.json",
  "title": "SRE Course Specification",
  "description": "Machine-readable course specification for SRE-based language learning courses",
  "type": "object",
  "required": ["course"],
  "properties": {
    "course": {
      "type": "object",
      "required": ["id", "title", "description", "learner_profile", "language", "experiences"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "learner_profile": { "type": "string" },
        "language": { "type": "string", "minLength": 2, "maxLength": 5 },
        "bridge_language": { "type": "string", "minLength": 2, "maxLength": 5 },
        "experiences": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/experience" }
        }
      }
    }
  },
  "definitions": {
    "experience": {
      "type": "object",
      "required": ["id", "title", "scenario", "level", "phrases", "content"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "title": { "type": "string" },
        "scenario": { "type": "string" },
        "level": { "type": "integer", "minimum": 1, "maximum": 5 },
        "entities": {
          "type": "array",
          "items": { "$ref": "#/definitions/entity" }
        },
        "affordances": {
          "type": "array",
          "items": { "$ref": "#/definitions/affordance" }
        },
        "phrases": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/phrase" }
        },
        "interactions": {
          "type": "array",
          "items": { "$ref": "#/definitions/interaction" }
        },
        "content": {
          "type": "object",
          "patternProperties": {
            "^[a-z]{2,5}$": { "type": "string" }
          }
        },
        "rehearsal": {
          "type": "array",
          "items": { "$ref": "#/definitions/rehearsal_step" }
        }
      }
    },
    "entity": {
      "type": "object",
      "required": ["id", "category"],
      "properties": {
        "id": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["THING", "PERSON", "ACTION", "STATE", "PLACE", "ANIMAL", "EMOTION", "QUALITY"]
        },
        "label": {
          "type": "object",
          "patternProperties": {
            "^[a-z]{2,5}$": { "type": "string" }
          }
        }
      }
    },
    "affordance": {
      "type": "object",
      "required": ["actor", "action"],
      "properties": {
        "actor": { "type": "string" },
        "action": { "type": "string" },
        "patient": { "type": "string" }
      }
    },
    "phrase": {
      "type": "object",
      "required": ["id", "semantic_intent", "surface_form", "learner_priority", "review_status"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z_0-9]+$" },
        "semantic_intent": { "type": "string" },
        "surface_form": {
          "type": "object",
          "patternProperties": {
            "^[a-z]{2,5}$": { "type": "string" }
          }
        },
        "learner_priority": {
          "type": "string",
          "enum": ["MUST_SAY", "RECOGNIZE", "CULTURAL"]
        },
        "review_status": {
          "type": "string",
          "enum": ["UNVERIFIED", "PENDING", "VERIFIED"]
        }
      }
    },
    "interaction": {
      "type": "object",
      "required": ["situation", "learner_action", "expected_intent"],
      "properties": {
        "situation": { "type": "string" },
        "learner_action": { "type": "string" },
        "expected_intent": { "type": "string" },
        "candidate_responses": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "rehearsal_step": {
      "type": "object",
      "required": ["role", "text"],
      "properties": {
        "role": { "type": "string", "enum": ["family", "learner", "narrator"] },
        "text": { "type": "string" },
        "expected": { "type": "string" }
      }
    }
  }
}
