{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sre.v0.1/canonical/entity",
  "title": "SRE Entity — Canonical Source",
  "description": "A node in the Semantic Representation Engine. Every entity represents something that exists in reality, independent of any language.",
  "type": "object",
  "required": ["entity_id", "category", "label"],
  "additionalProperties": false,
  "properties": {
    "entity_id": {
      "type": "string",
      "pattern": "^(THING|PERSON|PLACE|ACTION|STATE|PROPERTY|RELATION|EVENT|TIME|QUANTITY|EMOTION|SOCIAL)_\\d{3}$",
      "description": "Permanent unique identifier. Category prefix + 3-digit zero-padded number."
    },
    "category": {
      "type": "string",
      "enum": [
        "THING", "PERSON", "PLACE", "ACTION", "STATE",
        "PROPERTY", "RELATION", "EVENT", "TIME",
        "QUANTITY", "EMOTION", "SOCIAL"
      ],
      "description": "Universal ontology category. Language-independent."
    },
    "label": {
      "type": "object",
      "required": ["default"],
      "additionalProperties": false,
      "properties": {
        "default": {
          "type": "string",
          "description": "Neutral, language-independent label (could be English as lingua franca, but not the 'translation')."
        },
        "short": {
          "type": "string",
          "description": "Abbreviated label for constrained displays."
        }
      }
    },
    "definition": {
      "type": "string",
      "description": "Prose definition. For human readers. Not a substitute for representations or affordances."
    },
    "properties": {
      "type": "object",
      "description": "Arbitrary key-value properties. Must not duplicate information carried by representations, affordances, or relationships.",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" },
          { "type": "array", "items": { "type": "string" } }
        ]
      }
    },
    "metadata": {
      "type": "object",
      "description": "Source tracking and versioning.",
      "required": ["source", "confidence"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["manual", "sensor", "ai_generated", "derived"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "author": { "type": "string" },
        "created": { "type": "string", "format": "date-time" },
        "updated": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      }
    }
  }
}
