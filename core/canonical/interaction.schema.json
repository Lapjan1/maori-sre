{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sre.v0.1/canonical/interaction",
  "title": "SRE Interaction — Canonical Source",
  "description": "A specific event where one or more actors realize affordances. Interactions are immutable once recorded.",
  "type": "object",
  "required": ["interaction_id", "participants", "action"],
  "additionalProperties": false,
  "properties": {
    "interaction_id": {
      "type": "string",
      "pattern": "^INT_\\d{3}$",
      "description": "Permanent unique identifier for this interaction."
    },
    "participants": {
      "type": "array",
      "description": "Entities involved in the interaction. At least one must have role Actor.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "entity_id"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["Actor", "Patient", "Instrument", "Recipient", "Location", "Experiencer", "Stimulus"]
          },
          "entity_id": {
            "type": "string",
            "pattern": "^(THING|PERSON|PLACE|ACTION|STATE|PROPERTY|RELATION|EVENT|TIME|QUANTITY|EMOTION|SOCIAL)_\\d{3}$"
          }
        }
      }
    },
    "action": {
      "type": "string",
      "pattern": "^ACTION_\\d{3}$",
      "description": "The action entity_id. Should be an affordance of at least one participant."
    },
    "time": {
      "oneOf": [
        {
          "type": "object",
          "required": ["absolute"],
          "properties": {
            "absolute": { "type": "string", "format": "date-time" }
          }
        },
        {
          "type": "object",
          "required": ["label", "reference"],
          "properties": {
            "label": { "type": "string" },
            "reference": { "type": "string", "enum": ["RELATIVE", "CULTURAL", "SEASONAL"] }
          }
        }
      ]
    },
    "location": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^PLACE_\\d{3}$"
        },
        {
          "type": "object",
          "required": ["latitude", "longitude"],
          "properties": {
            "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
            "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
          }
        }
      ]
    },
    "outcomes": {
      "type": "array",
      "description": "Resulting states, emotions, or events.",
      "items": {
        "type": "object",
        "required": ["entity_id"],
        "properties": {
          "entity_id": {
            "type": "string",
            "pattern": "^(STATE|EMOTION|EVENT)_\\d{3}$"
          },
          "description": { "type": "string" }
        }
      }
    },
    "language_examples": {
      "type": "object",
      "description": "Example sentences describing this interaction, keyed by language code.",
      "additionalProperties": {
        "type": "string"
      }
    },
    "superseded_by": {
      "type": "string",
      "pattern": "^INT_\\d{3}$",
      "description": "If set, this interaction was recorded in error and superseded by another."
    },
    "metadata": {
      "type": "object",
      "required": ["source", "confidence"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["manual", "sensor", "ai_generated", "derived"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "recorded": { "type": "string", "format": "date-time" }
      }
    }
  }
}
